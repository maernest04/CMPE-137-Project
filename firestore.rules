rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and write their own user data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Spaces: anyone can read, authenticated users can create
    match /spaces/{spaceId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false; // No client updates/deletes to spaces

      // Reviews under each space
      match /reviews/{reviewId} {
        // Anyone can read reviews
        allow read: if true;
        
        // Authenticated users can create reviews
        allow create: if request.auth != null && 
                         request.resource.data.userId == request.auth.uid;
        
        // Users can edit/delete only their own reviews
        allow update, delete: if request.auth != null && 
                                 resource.data.userId == request.auth.uid;
      }
    }
  }
}
