rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and write their own user data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Spaces are readable by everyone
    match /spaces/{spaceId} {
      allow read: if true;
      // Allow authenticated users to create/update spaces if needed
      allow write: if request.auth != null;
    }

    // Reviews are readable by everyone, but writes are handled by Cloud Functions
    match /spaces/{spaceId}/reviews/{reviewId} {
      allow read: if true;
      allow write: if false; // Deny client writes to prevent unauthorized access
    }
  }
}